---
import { imgUrl, imgSrcset, lightboxUrl } from '../utils/cloudinary';

interface Photo {
  publicId: string;
  album: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;

const lightboxData = photos.map(p => ({
  src: lightboxUrl(p.publicId),
  alt: p.alt,
  caption: p.caption ?? '',
}));
---

<div class="masonry" id="masonry">
  {photos.map((photo, i) => (
    <button
      class="photo-btn"
      data-index={i}
      aria-label={`View ${photo.alt}`}
      type="button"
    >
      <img
        src={imgUrl(photo.publicId, 800)}
        srcset={imgSrcset(photo.publicId)}
        sizes="(max-width: 600px) 100vw, (max-width: 960px) 50vw, 33vw"
        alt={photo.alt}
        width={photo.width}
        height={photo.height}
        loading="lazy"
        decoding="async"
      />
    </button>
  ))}
</div>

<!-- Lightbox — z-index 150, below sidebar (200) -->
<div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
  <button class="lb-close" id="lb-close" aria-label="Close" type="button">✕</button>
  <button class="lb-prev" id="lb-prev" aria-label="Previous photo" type="button">&#8249;</button>
  <button class="lb-next" id="lb-next" aria-label="Next photo" type="button">&#8250;</button>
  <div class="lb-stage">
    <img id="lb-img" src="" alt="" />
    <p class="lb-caption" id="lb-caption"></p>
  </div>
</div>

<script define:vars={{ lightboxData }}>
  const lightbox  = document.getElementById('lightbox');
  const lbImg     = document.getElementById('lb-img');
  const lbCaption = document.getElementById('lb-caption');
  const lbClose   = document.getElementById('lb-close');
  const lbPrev    = document.getElementById('lb-prev');
  const lbNext    = document.getElementById('lb-next');
  const photos    = lightboxData;
  let current     = 0;

  function show(index) {
    const p = photos[index];
    lbImg.src        = p.src;
    lbImg.alt        = p.alt;
    lbCaption.textContent = p.caption;
    lbCaption.hidden = !p.caption;
  }

  function open(index) {
    current = index;
    show(current);
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
    lbClose.focus();
  }

  function close() {
    lightbox.hidden = true;
    document.body.style.overflow = '';
    document.querySelector(`[data-index="${current}"]`)?.focus();
  }

  function prev() { current = (current - 1 + photos.length) % photos.length; show(current); }
  function next() { current = (current + 1) % photos.length; show(current); }

  document.getElementById('masonry').addEventListener('click', e => {
    const btn = e.target.closest('[data-index]');
    if (btn) open(parseInt(btn.dataset.index, 10));
  });

  lbClose.addEventListener('click', close);
  lbPrev.addEventListener('click', prev);
  lbNext.addEventListener('click', next);

  lightbox.addEventListener('click', e => { if (e.target === lightbox) close(); });

  document.addEventListener('keydown', e => {
    if (lightbox.hidden) return;
    if (e.key === 'Escape')      close();
    if (e.key === 'ArrowLeft')   prev();
    if (e.key === 'ArrowRight')  next();
  });

  let touchStartX = 0;
  lightbox.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  lightbox.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (dx > 50) prev();
    else if (dx < -50) next();
  }, { passive: true });
</script>

<style>
  .masonry {
    column-count: 3;
    column-gap: var(--gap);
    padding: var(--gap);
  }

  .photo-btn {
    display: block;
    width: 100%;
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    break-inside: avoid;
    margin-bottom: var(--gap);
  }

  .photo-btn img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.18s;
  }

  .photo-btn:hover img {
    opacity: 0.85;
  }

  /* Lightbox sits above content but BELOW the sidebar (z-index 200) */
  .lightbox {
    position: fixed;
    /* starts at sidebar edge on desktop so sidebar shows through */
    left: var(--sidebar-w);
    right: 0;
    top: 0;
    bottom: 0;
    background: rgba(249, 249, 247, 0.94);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 150;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lb-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: calc(100% - 100px);
    max-height: 90vh;
  }

  .lb-stage img {
    max-width: 100%;
    max-height: 82vh;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .lb-caption {
    margin-top: 12px;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-align: center;
  }

  .lb-close,
  .lb-prev,
  .lb-next {
    position: fixed;
    background: none;
    border: none;
    color: var(--text);
    cursor: pointer;
    z-index: 151;
    opacity: 0.45;
    transition: opacity 0.15s;
  }
  .lb-close:hover,
  .lb-prev:hover,
  .lb-next:hover {
    opacity: 1;
  }

  .lb-close {
    top: 18px;
    right: 22px;
    font-size: 18px;
    padding: 6px 10px;
  }

  .lb-prev {
    left: calc(var(--sidebar-w) + 12px);
    top: 50%;
    transform: translateY(-50%);
    font-size: 44px;
    padding: 8px 12px;
    line-height: 1;
  }

  .lb-next {
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 44px;
    padding: 8px 12px;
    line-height: 1;
  }

  @media (max-width: 960px) {
    .masonry { column-count: 2; }
  }

  @media (max-width: 767px) {
    .masonry { column-count: 2; }

    /* On mobile, lightbox covers full screen (no sidebar) */
    .lightbox {
      left: 0;
    }
    .lb-prev {
      left: 4px;
    }
  }

  @media (max-width: 480px) {
    .masonry { column-count: 1; }
  }
</style>
