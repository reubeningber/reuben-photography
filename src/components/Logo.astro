---
interface Props {
  variant: 'horizontal-dark' | 'horizontal-light' | 'stacked-dark' | 'stacked-light';
  class?: string;
}
const { variant, class: className = '' } = Astro.props;

const isH  = variant.startsWith('horizontal');
const isDk = variant.endsWith('dark');

const BG = isDk ? '#1a1a18' : '#f0ede6';
const DETAIL = '#1a1a18';
const CUTOUT = isDk ? '#ede8dc' : '#ffffff';
const DIVIDER = isDk ? '#ede8dc' : '#d7cfc1';

// Unique ID prefix per variant — assumes one instance of each variant per page
const uid = `logo-${variant.replace(/-/g, '')}`;
---

{isH ? (
  <!-- ── Horizontal 360 × 64 ───────────────────────────────────── -->
  <svg viewBox="0 0 360 64" xmlns="http://www.w3.org/2000/svg"
       role="img" aria-label="Reuben Ingber"
       class={className} style="display:block;width:100%;height:auto">

    <rect width="360" height="64" fill={BG}/>

    <!-- Camera icon closer to the flat reference silhouette -->
    <g transform="translate(8,9)">
      <path d="M6 11h10.8c1.6 0 2.9-1.3 2.9-2.9V6.4c0-2 1.6-3.4 3.5-3.4h11.7c1.9 0 3.5 1.4 3.5 3.4v1.7c0 1.6 1.3 2.9 2.9 2.9H46c3.3 0 6 2.7 6 6v18c0 3.3-2.7 6-6 6H6c-3.3 0-6-2.7-6-6V17c0-3.3 2.7-6 6-6Z" fill="#ea580c"/>
      <rect x="3.5" y="6.2" width="9.2" height="4.2" rx="1.4" fill="#ea580c"/>
      <rect x="39.5" y="13.2" width="10.6" height="5.8" rx="1.4" fill={CUTOUT}/>
      <path d="M0.8 16.1H9.1c2.4 0 4.3 1.9 4.3 4.3v12.8c0 2.4-1.9 4.3-4.3 4.3H0.8"
            fill="none" stroke={CUTOUT} stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="29.4" cy="26.6" r="10.2" fill="none" stroke={CUTOUT} stroke-width="4.3"/>
    </g>

    <!-- Vertical divider -->
    <line x1="70" y1="13" x2="70" y2="51"
          stroke={DIVIDER} stroke-width="1" opacity="0.6"/>

    <defs>
      <clipPath id={`${uid}-c`}>
        <text x="80" y="43"
              font-family="Impact,sans-serif" font-size="38" letter-spacing="2">
          REUBEN INGBER
        </text>
      </clipPath>
    </defs>

    <!-- REUBEN INGBER — layer 1: shadow -->
    <text x="84" y="47"
          font-family="Impact,sans-serif" font-size="38" letter-spacing="2"
          fill="#ea580c">REUBEN INGBER</text>
    <!-- REUBEN INGBER — layer 2: gap fill -->
    <text x="84" y="47"
          font-family="Impact,sans-serif" font-size="38" letter-spacing="2"
          fill="#ea580c" stroke="#ea580c" stroke-width="20" stroke-linejoin="miter"
          clip-path={`url(#${uid}-c)`}>REUBEN INGBER</text>
    <!-- REUBEN INGBER — layer 3: white top -->
    <text x="80" y="43"
          font-family="Impact,sans-serif" font-size="38" letter-spacing="2"
          fill="#ffffff">REUBEN INGBER</text>

  </svg>
) : (
  <!-- ── Stacked 220 × 196 ──────────────────────────────────────── -->
  <svg viewBox="0 0 220 196" xmlns="http://www.w3.org/2000/svg"
       role="img" aria-label="Reuben Ingber"
       class={className} style="display:block;width:100%;height:auto">

    <rect width="220" height="196" fill={BG}/>

    <!-- Larger camera icon closer to the flat reference silhouette -->
    <g transform="translate(71,8) scale(1.5)">
      <path d="M6 11h10.8c1.6 0 2.9-1.3 2.9-2.9V6.4c0-2 1.6-3.4 3.5-3.4h11.7c1.9 0 3.5 1.4 3.5 3.4v1.7c0 1.6 1.3 2.9 2.9 2.9H46c3.3 0 6 2.7 6 6v18c0 3.3-2.7 6-6 6H6c-3.3 0-6-2.7-6-6V17c0-3.3 2.7-6 6-6Z" fill="#ea580c"/>
      <rect x="3.5" y="6.2" width="9.2" height="4.2" rx="1.4" fill="#ea580c"/>
      <rect x="39.5" y="13.2" width="10.6" height="5.8" rx="1.4" fill={CUTOUT}/>
      <path d="M0.8 16.1H9.1c2.4 0 4.3 1.9 4.3 4.3v12.8c0 2.4-1.9 4.3-4.3 4.3H0.8"
            fill="none" stroke={CUTOUT} stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="29.4" cy="26.6" r="10.2" fill="none" stroke={CUTOUT} stroke-width="4.3"/>
    </g>

    <defs>
      <clipPath id={`${uid}-r`}>
        <text x="110" y="123" text-anchor="middle"
              font-family="Impact,sans-serif" font-size="54" letter-spacing="2.5">
          REUBEN
        </text>
      </clipPath>
      <clipPath id={`${uid}-i`}>
        <text x="110" y="171" text-anchor="middle"
              font-family="Impact,sans-serif" font-size="54" letter-spacing="2.5">
          INGBER
        </text>
      </clipPath>
    </defs>

    <!-- REUBEN — layer 1: shadow -->
    <text x="114" y="128" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="54" letter-spacing="2.5"
          fill="#ea580c">REUBEN</text>
    <!-- REUBEN — layer 2: gap fill -->
    <text x="114" y="128" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="54" letter-spacing="2.5"
          fill="#ea580c" stroke="#ea580c" stroke-width="20" stroke-linejoin="miter"
          clip-path={`url(#${uid}-r)`}>REUBEN</text>
    <!-- REUBEN — layer 3: white -->
    <text x="110" y="123" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="54" letter-spacing="2.5"
          fill="#ffffff">REUBEN</text>

    <!-- INGBER — layer 1: shadow -->
    <text x="114" y="176" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="54" letter-spacing="2.5"
          fill="#ea580c">INGBER</text>
    <!-- INGBER — layer 2: gap fill -->
    <text x="114" y="176" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="54" letter-spacing="2.5"
          fill="#ea580c" stroke="#ea580c" stroke-width="20" stroke-linejoin="miter"
          clip-path={`url(#${uid}-i)`}>INGBER</text>
    <!-- INGBER — layer 3: white -->
    <text x="110" y="171" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="54" letter-spacing="2.5"
          fill="#ffffff">INGBER</text>

  </svg>
)}
