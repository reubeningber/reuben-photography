---
interface Props {
  variant: 'horizontal-dark' | 'horizontal-light' | 'stacked-dark' | 'stacked-light';
  class?: string;
}
const { variant, class: className = '' } = Astro.props;

const isH  = variant.startsWith('horizontal');
const isDk = variant.endsWith('dark');

// Color tokens per variant
const BG = isDk ? '#1a1a18' : '#f0ede6';
const LO = isDk ? '#ede8dc' : '#1a1a18';  // lens outer ring + flash
const RI = isDk ? '#ede8dc' : '#1a1a18';  // rule / divider line

// ClipPath IDs — unique per variant; assumes one instance per variant per page
const uid = `logo-${variant.replace(/-/g, '')}`;
---

{isH ? (
  <!-- ── Horizontal logo  320 × 52 ─────────────────────────────── -->
  <svg viewBox="0 0 320 52" xmlns="http://www.w3.org/2000/svg"
       role="img" aria-label="Reuben Ingber"
       class={className} style="display:block;width:100%;height:auto">

    <rect width="320" height="52" fill={BG}/>

    <!-- Camera icon, native 44 × 34, anchored at (10, 9) -->
    <g transform="translate(10,9)">
      <!-- Body -->
      <rect x="0"  y="10" width="44" height="24" rx="4" fill="#ea580c"/>
      <!-- Viewfinder bump -->
      <rect x="14" y="2"  width="13" height="11" rx="3" fill="#ea580c"/>
      <!-- Flash (top-right, lens-outer color) -->
      <rect x="32" y="3"  width="8"  height="7"  rx="2" fill={LO}/>
      <!-- Lens outer ring -->
      <circle cx="21" cy="22" r="8"   fill={LO}/>
      <!-- Lens inner (orange) -->
      <circle cx="21" cy="22" r="5.5" fill="#ea580c"/>
      <!-- Lens center dot (background color) -->
      <circle cx="21" cy="22" r="2"   fill={BG}/>
    </g>

    <!-- Vertical divider -->
    <line x1="62" y1="11" x2="62" y2="41"
          stroke={RI} stroke-width="0.75" opacity="0.35"/>

    <defs>
      <!-- ClipPath defines the base-text glyph shapes for gap-fill layer -->
      <clipPath id={`${uid}-c`}>
        <text x="72" y="33"
              font-family="Impact,sans-serif" font-size="26" letter-spacing="4">
          REUBEN INGBER
        </text>
      </clipPath>
    </defs>

    <!-- Layer 1 — orange shadow (base + 3 right, + 4 down) -->
    <text x="75" y="37"
          font-family="Impact,sans-serif" font-size="26" letter-spacing="4"
          fill="#ea580c">REUBEN INGBER</text>

    <!-- Layer 2 — gap fill: shadow position, thick stroke, clipped to base bounds -->
    <text x="75" y="37"
          font-family="Impact,sans-serif" font-size="26" letter-spacing="4"
          fill="#ea580c" stroke="#ea580c" stroke-width="14" stroke-linejoin="miter"
          clip-path={`url(#${uid}-c)`}>REUBEN INGBER</text>

    <!-- Layer 3 — white top text at base position -->
    <text x="72" y="33"
          font-family="Impact,sans-serif" font-size="26" letter-spacing="4"
          fill="#ffffff">REUBEN INGBER</text>

  </svg>
) : (
  <!-- ── Stacked logo  190 × 148 ───────────────────────────────── -->
  <svg viewBox="0 0 190 148" xmlns="http://www.w3.org/2000/svg"
       role="img" aria-label="Reuben Ingber"
       class={className} style="display:block;width:100%;height:auto">

    <rect width="190" height="148" fill={BG}/>

    <!-- Camera icon, native 44 × 34, scaled 1.25× and horizontally centered -->
    <!-- Rendered size: 55 × 42.5 — translate centers in 190px: (190-55)/2 = 67.5 -->
    <g transform="translate(67.5,8) scale(1.25)">
      <rect x="0"  y="10" width="44" height="24" rx="4" fill="#ea580c"/>
      <rect x="14" y="2"  width="13" height="11" rx="3" fill="#ea580c"/>
      <rect x="32" y="3"  width="8"  height="7"  rx="2" fill={LO}/>
      <circle cx="21" cy="22" r="8"   fill={LO}/>
      <circle cx="21" cy="22" r="5.5" fill="#ea580c"/>
      <circle cx="21" cy="22" r="2"   fill={BG}/>
    </g>

    <defs>
      <clipPath id={`${uid}-r`}>
        <text x="95" y="90" text-anchor="middle"
              font-family="Impact,sans-serif" font-size="36" letter-spacing="4">
          REUBEN
        </text>
      </clipPath>
      <clipPath id={`${uid}-i`}>
        <text x="95" y="128" text-anchor="middle"
              font-family="Impact,sans-serif" font-size="36" letter-spacing="4">
          INGBER
        </text>
      </clipPath>
    </defs>

    <!-- REUBEN — Layer 1: shadow -->
    <text x="98" y="94" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ea580c">REUBEN</text>
    <!-- REUBEN — Layer 2: gap fill -->
    <text x="98" y="94" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ea580c" stroke="#ea580c" stroke-width="14" stroke-linejoin="miter"
          clip-path={`url(#${uid}-r)`}>REUBEN</text>
    <!-- REUBEN — Layer 3: white -->
    <text x="95" y="90" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ffffff">REUBEN</text>

    <!-- INGBER — Layer 1: shadow -->
    <text x="98" y="132" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ea580c">INGBER</text>
    <!-- INGBER — Layer 2: gap fill -->
    <text x="98" y="132" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ea580c" stroke="#ea580c" stroke-width="14" stroke-linejoin="miter"
          clip-path={`url(#${uid}-i)`}>INGBER</text>
    <!-- INGBER — Layer 3: white -->
    <text x="95" y="128" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ffffff">INGBER</text>

    <!-- Horizontal rule below text -->
    <line x1="20" y1="138" x2="170" y2="138"
          stroke={RI} stroke-width="0.75" opacity="0.35"/>

  </svg>
)}
