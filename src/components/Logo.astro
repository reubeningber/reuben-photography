---
interface Props {
  variant: 'horizontal-dark' | 'horizontal-light' | 'stacked-dark' | 'stacked-light';
  class?: string;
}
const { variant, class: className = '' } = Astro.props;

const isH  = variant.startsWith('horizontal');
const isDk = variant.endsWith('dark');

const BG = isDk ? '#1a1a18' : '#f0ede6';
const LO = isDk ? '#ede8dc' : '#1a1a18';  // lens outer ring + flash
const RI = isDk ? '#ede8dc' : '#1a1a18';  // rule / divider

// Unique ID prefix per variant — assumes one instance of each variant per page
const uid = `logo-${variant.replace(/-/g, '')}`;
---

{isH ? (
  <!-- ── Horizontal  320 × 58 ──────────────────────────────────── -->
  <svg viewBox="0 0 320 58" xmlns="http://www.w3.org/2000/svg"
       role="img" aria-label="Reuben Ingber Photography"
       class={className} style="display:block;width:100%;height:auto">

    <rect width="320" height="58" fill={BG}/>

    <!-- Camera icon, native 44 × 36, vertically centred in 58px → translate(8,11) -->
    <g transform="translate(8,11)">
      <!-- Body — rx=8 for rounded look -->
      <rect x="0"  y="10" width="44" height="26" rx="8"  fill="#ea580c"/>
      <!-- Viewfinder bump -->
      <rect x="13" y="2"  width="14" height="12" rx="4"  fill="#ea580c"/>
      <!-- Flash (top-right of bump area, lens-outer colour) -->
      <rect x="32" y="3"  width="7"  height="6"  rx="3"  fill={LO}/>
      <!-- Lens outer ring -->
      <circle cx="21" cy="23" r="9"   fill={LO}/>
      <!-- Lens inner (orange) -->
      <circle cx="21" cy="23" r="6"   fill="#ea580c"/>
      <!-- Lens centre dot (background colour) -->
      <circle cx="21" cy="23" r="2.5" fill={BG}/>
    </g>

    <!-- Vertical divider -->
    <line x1="61" y1="12" x2="61" y2="46"
          stroke={RI} stroke-width="0.75" opacity="0.35"/>

    <defs>
      <clipPath id={`${uid}-c`}>
        <text x="71" y="30"
              font-family="Impact,sans-serif" font-size="22" letter-spacing="4">
          REUBEN INGBER
        </text>
      </clipPath>
    </defs>

    <!-- REUBEN INGBER — layer 1: shadow -->
    <text x="74" y="34"
          font-family="Impact,sans-serif" font-size="22" letter-spacing="4"
          fill="#ea580c">REUBEN INGBER</text>
    <!-- REUBEN INGBER — layer 2: gap fill -->
    <text x="74" y="34"
          font-family="Impact,sans-serif" font-size="22" letter-spacing="4"
          fill="#ea580c" stroke="#ea580c" stroke-width="14" stroke-linejoin="miter"
          clip-path={`url(#${uid}-c)`}>REUBEN INGBER</text>
    <!-- REUBEN INGBER — layer 3: white top -->
    <text x="71" y="30"
          font-family="Impact,sans-serif" font-size="22" letter-spacing="4"
          fill="#ffffff">REUBEN INGBER</text>

    <!-- PHOTOGRAPHY subtitle — flat, no shadow -->
    <text x="71" y="46"
          font-family="Impact,sans-serif" font-size="10" letter-spacing="3"
          fill="#ea580c">PHOTOGRAPHY</text>

  </svg>
) : (
  <!-- ── Stacked  190 × 168 ─────────────────────────────────────── -->
  <svg viewBox="0 0 190 168" xmlns="http://www.w3.org/2000/svg"
       role="img" aria-label="Reuben Ingber Photography"
       class={className} style="display:block;width:100%;height:auto">

    <rect width="190" height="168" fill={BG}/>

    <!-- Camera icon, native 44 × 36, scaled 1.25× (→ 55 × 45), centred horizontally -->
    <!-- translate x = (190 − 44×1.25) / 2 = (190 − 55) / 2 = 67.5               -->
    <!-- camera top rendered ≈ y=10.5  bottom ≈ y=53                               -->
    <g transform="translate(67.5,8) scale(1.25)">
      <rect x="0"  y="10" width="44" height="26" rx="8"  fill="#ea580c"/>
      <rect x="13" y="2"  width="14" height="12" rx="4"  fill="#ea580c"/>
      <rect x="32" y="3"  width="7"  height="6"  rx="3"  fill={LO}/>
      <circle cx="21" cy="23" r="9"   fill={LO}/>
      <circle cx="21" cy="23" r="6"   fill="#ea580c"/>
      <circle cx="21" cy="23" r="2.5" fill={BG}/>
    </g>

    <defs>
      <clipPath id={`${uid}-r`}>
        <text x="95" y="90" text-anchor="middle"
              font-family="Impact,sans-serif" font-size="36" letter-spacing="4">
          REUBEN
        </text>
      </clipPath>
      <clipPath id={`${uid}-i`}>
        <text x="95" y="128" text-anchor="middle"
              font-family="Impact,sans-serif" font-size="36" letter-spacing="4">
          INGBER
        </text>
      </clipPath>
    </defs>

    <!-- REUBEN — layer 1: shadow -->
    <text x="98" y="94" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ea580c">REUBEN</text>
    <!-- REUBEN — layer 2: gap fill -->
    <text x="98" y="94" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ea580c" stroke="#ea580c" stroke-width="14" stroke-linejoin="miter"
          clip-path={`url(#${uid}-r)`}>REUBEN</text>
    <!-- REUBEN — layer 3: white -->
    <text x="95" y="90" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ffffff">REUBEN</text>

    <!-- INGBER — layer 1: shadow -->
    <text x="98" y="132" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ea580c">INGBER</text>
    <!-- INGBER — layer 2: gap fill -->
    <text x="98" y="132" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ea580c" stroke="#ea580c" stroke-width="14" stroke-linejoin="miter"
          clip-path={`url(#${uid}-i)`}>INGBER</text>
    <!-- INGBER — layer 3: white -->
    <text x="95" y="128" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="36" letter-spacing="4"
          fill="#ffffff">INGBER</text>

    <!-- Horizontal rule -->
    <line x1="22" y1="138" x2="168" y2="138"
          stroke={RI} stroke-width="0.75" opacity="0.35"/>

    <!-- PHOTOGRAPHY subtitle — flat, no shadow -->
    <text x="95" y="154" text-anchor="middle"
          font-family="Impact,sans-serif" font-size="10" letter-spacing="4"
          fill="#ea580c">PHOTOGRAPHY</text>

  </svg>
)}
