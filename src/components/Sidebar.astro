---
import { albums } from '../data/albums';
import LogoStackedLight from './LogoStackedLight.astro';
import LogoHorizontalLight from './LogoHorizontalLight.astro';

const path = Astro.url.pathname;
const isActive = (slug: string) => path === `/${slug}` || path === `/${slug}/`;
---

<!-- Desktop sidebar -->
<aside class="sidebar">
  <div class="sidebar-inner">
    <a href="/" class="logo-link" aria-label="Home">
      <LogoStackedLight />
    </a>

    <nav class="sidebar-nav">
      {albums.map(album => (
        <a href={`/${album.slug}`} class:list={[{ active: isActive(album.slug) }]}>
          {album.label}
        </a>
      ))}
      <a href="/contact" class:list={[{ active: isActive('contact') }]}>Contact</a>
    </nav>

    <div class="sidebar-foot">
      <div class="social-links">
        <a
          href="https://instagram.com/reuben_in_color"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="social-link"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3.25" y="3.25" width="17.5" height="17.5" rx="5" />
            <circle cx="12" cy="12" r="4.25" />
            <circle cx="17.4" cy="6.6" r="1.15" />
          </svg>
        </a>
      </div>
      <a href="https://reubeningber.com" target="_blank" rel="noopener noreferrer">
        about &amp; writing →
      </a>
    </div>
  </div>
</aside>

<!-- Mobile top bar -->
<div class="mobile-bar">
  <a href="/" class="mobile-logo-link" aria-label="Home">
    <LogoHorizontalLight />
  </a>
  <button class="hamburger" id="hamburger" aria-label="Open navigation" type="button">
    <span></span><span></span><span></span>
  </button>
</div>

<!-- Mobile drawer -->
<div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
  <button class="drawer-close" id="drawer-close" aria-label="Close navigation" type="button">✕</button>

  <a href="/" class="drawer-logo-link" aria-label="Home">
    <LogoHorizontalLight />
  </a>

  <nav class="sidebar-nav">
    {albums.map(album => (
      <a href={`/${album.slug}`}>{album.label}</a>
    ))}
    <a href="/contact">Contact</a>
  </nav>

  <div class="sidebar-foot">
    <div class="social-links">
      <a
        href="https://instagram.com/reuben_in_color"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="social-link"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <rect x="3.25" y="3.25" width="17.5" height="17.5" rx="5" />
          <circle cx="12" cy="12" r="4.25" />
          <circle cx="17.4" cy="6.6" r="1.15" />
        </svg>
      </a>
    </div>
    <a href="https://reubeningber.com" target="_blank" rel="noopener noreferrer">
      about &amp; writing →
    </a>
  </div>
</div>

<script>
  const hamburger = document.getElementById('hamburger')!;
  const drawer    = document.getElementById('mobile-drawer')!;
  const closeBtn  = document.getElementById('drawer-close')!;

  function open() {
    drawer.classList.add('open');
    drawer.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }
  function close() {
    drawer.classList.remove('open');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    hamburger.focus();
  }

  hamburger.addEventListener('click', open);
  closeBtn.addEventListener('click', close);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
</script>

<style>
  /* ── Desktop sidebar ── */
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: var(--sidebar-w);
    height: 100vh;
    background: var(--bg);
    z-index: 200;
    overflow-y: auto;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    padding: 24px 0 44px;
  }

  .logo-link {
    display: block;
    width: min(252px, calc(100% - 44px));
    margin: 0 auto 40px;
    flex-shrink: 0;
  }
  .logo-link svg {
    display: block;
    width: 100%;
    height: auto;
  }
  .logo-link:hover { opacity: 0.9; }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    padding: 0 36px;
    text-align: center;
  }

  .sidebar-nav a {
    font-size: 14px;
    letter-spacing: 0.12em;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0.55;
    display: block;
    transition: opacity 0.15s;
  }

  .sidebar-nav a:hover,
  .sidebar-nav a.active {
    opacity: 1;
  }

  .sidebar-foot {
    margin-top: auto;
    padding: 48px 36px 0;
    text-align: center;
  }

  .social-links {
    display: flex;
    justify-content: center;
    margin-bottom: 18px;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: var(--muted);
    transition: color 0.15s, opacity 0.15s;
  }

  .social-link svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
  }

  .social-link:hover {
    color: var(--text);
    opacity: 1;
  }

  .sidebar-foot a {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.03em;
  }
  .sidebar-foot a:hover { opacity: 0.55; }

  /* ── Mobile bar + drawer (hidden on desktop) ── */
  .mobile-bar,
  .mobile-drawer {
    display: none;
  }

  /* ── Mobile breakpoint ── */
  @media (max-width: 767px) {
    .sidebar { display: none; }

    .mobile-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 44px;
      padding: 0;
      background: var(--bg);
      z-index: 200;
      overflow: hidden;
    }

    /* Scale the horizontal logo to fit the mobile bar height */
    .mobile-logo-link {
      display: block;
      height: 44px;
      width: 248px;
      flex-shrink: 0;
    }
    .mobile-logo-link svg {
      height: 44px;
      width: auto;
    }
    .mobile-logo-link:hover { opacity: 0.9; }

    .hamburger {
      background: none;
      border: none;
      cursor: pointer;
      width: 56px;
      height: 44px;
      padding: 0 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      flex-shrink: 0;
    }
    .hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--text);
      flex: 0 0 auto;
    }

    /* Drawer */
    .mobile-drawer {
      display: flex;
      flex-direction: column;
      position: fixed;
      top: 0;
      left: 0;
      width: 85vw;
      height: 100vh;
      background: var(--bg);
      z-index: 300;
      padding: 28px 28px 48px;
      overflow-y: auto;
      transform: translateX(-100%);
      transition: transform 0.26s ease;
    }

    .mobile-drawer.open {
      transform: translateX(0);
    }

    .drawer-close {
      position: absolute;
      top: 16px;
      right: 20px;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 18px;
      color: var(--text);
      padding: 4px 8px;
    }

    .drawer-logo-link {
      display: block;
      width: min(250px, calc(100% - 48px));
      margin: 4px 0 36px;
    }
    .drawer-logo-link svg {
      display: block;
      width: 100%;
      height: auto;
    }
    .drawer-logo-link:hover { opacity: 0.9; }

    .mobile-drawer .sidebar-nav {
      align-items: flex-start;
      gap: 20px;
      padding: 0;
      text-align: left;
    }

    .mobile-drawer .sidebar-nav a {
      font-size: 14px;
      letter-spacing: 0.1em;
    }

    .mobile-drawer .sidebar-foot {
      padding: 40px 0 0;
    }

    .mobile-drawer .social-links {
      justify-content: flex-start;
    }
  }
</style>
