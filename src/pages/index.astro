---
import Layout from '../layouts/Layout.astro';
import { imgUrl } from '../utils/cloudinary';
import { HERO_PHOTO_ID } from '../data/config';
---

<Layout>
  <div class="hero">
    <img
      src={imgUrl(HERO_PHOTO_ID, 1600)}
      alt="Hero photograph"
      loading="eager"
      decoding="async"
    />
  </div>
</Layout>

<style>
  .hero {
    height: 100dvh;
    overflow: hidden;
  }

  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 767px) {
    .hero {
      height: calc(100dvh - 52px);
    }
  }
</style>
